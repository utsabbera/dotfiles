[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign

[user]
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIFx/IjcX4xPQVRLblSH8yl47PBl+0cUTMLWk9zl2THvS
	name = Utsab Bera
	email = utsabbera@users.noreply.github.com

[commit]
	gpgsign = false

[includeIf "gitdir:~/tw/"]
	path = ~/.gitconfig-work
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
